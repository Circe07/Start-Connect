## StartAndConnect (Backend)

# Required for /auth/login and /auth/refresh (Firebase Identity Toolkit / Secure Token API)
AUTH_API_KEY=

# Firebase Admin SDK project/database selection (optional)
# Defaults are set in code for this repo, but having them here makes setup explicit.
FIREBASE_PROJECT_ID=startandconnect-c44b2
FIREBASE_DATABASE_ID=startandconnect-eur3

# CORS allowlist (comma separated). If empty, backend allows all (dev default).
# Example: https://myapp.com,https://admin.myapp.com
CORS_ORIGINS=

# Auth rate limiting (anti brute force)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

