    {
      "name": "03d - List Experiences by center_id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var body = pm.response.json();",
              "pm.test('all returned experiences match center_id filter', function () {",
              "  pm.expect(Array.isArray(body.experiences)).to.eql(true);",
              "  body.experiences.forEach(function (e) {",
              "    pm.expect(e.center_id).to.eql(pm.environment.get('validCenterId'));",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/v1/experiences?center_id={{validCenterId}}&limit=20"
      }
    },
