    {
      "name": "03b - Create Experience with center_id (admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var body = pm.response.json();",
              "pm.environment.set('experienceIdWithCenter', body.experience.id);",
              "pm.environment.set('experienceIdV2', body.experience.id);",
              "pm.test('response carries center_id', function () {",
              "  pm.expect(body.experience.center_id).to.eql(pm.environment.get('validCenterId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Partido Test QA Center\",\n  \"descripcion\": \"Partido para validar center_id\",\n  \"deporte_vertical\": \"padel\",\n  \"ciudad\": \"Madrid\",\n  \"club\": \"Club QA Center\",\n  \"direccion\": \"Calle Centro 99\",\n  \"fecha\": \"{{experienceDate}}\",\n  \"hora_inicio\": \"12:00\",\n  \"hora_fin\": \"13:30\",\n  \"nivel_permitido\": \"medio\",\n  \"plazas_totales\": 2,\n  \"precio\": 20,\n  \"host_asignado\": \"{{hostId}}\",\n  \"center_id\": \"{{validCenterId}}\",\n  \"politica_cancelacion\": \"Cancelacion hasta 24h antes\",\n  \"instrucciones\": \"Traer pala y agua\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/experiences"
      }
