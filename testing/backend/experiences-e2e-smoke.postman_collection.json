{
  "info": {
    "name": "StartAndConnect Experiences E2E Smoke",
    "_postman_id": "b03ad3c9-a37a-4af5-96f4-eaf4ff32c61d",
    "description": "Minimal end-to-end smoke for experiences, bookings, feedback, referrals, hosts and admin exports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Health",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var body = pm.response.json();",
              "pm.test('health is ok', function () {",
              "  pm.expect(body.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
