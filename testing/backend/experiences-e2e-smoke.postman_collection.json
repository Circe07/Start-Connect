        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Partido Test QA Invalid Center\",\n  \"descripcion\": \"Partido para validar center_id invalido\",\n  \"deporte_vertical\": \"padel\",\n  \"ciudad\": \"Madrid\",\n  \"club\": \"Club QA\",\n  \"direccion\": \"Calle Test 124\",\n  \"fecha\": \"{{experienceDate}}\",\n  \"hora_inicio\": \"14:00\",\n  \"hora_fin\": \"15:00\",\n  \"nivel_permitido\": \"medio\",\n  \"plazas_totales\": 2,\n  \"precio\": 18,\n  \"host_asignado\": \"{{hostId}}\",\n  \"center_id\": \"{{invalidCenterId}}\",\n  \"politica_cancelacion\": \"Cancelacion hasta 24h antes\",\n  \"instrucciones\": \"Traer pala y agua\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/experiences"
      }
