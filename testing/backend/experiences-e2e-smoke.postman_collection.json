        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Host QA\",\n  \"telefono\": \"+34600111222\",\n  \"nivel_aproximado\": \"medio\",\n  \"disponibilidad\": \"fines de semana\",\n  \"estado\": \"junior\",\n  \"partidas_realizadas\": 12,\n  \"nps_medio\": 8.4,\n  \"observaciones\": \"Creado desde smoke\"\n}"
