# Firebase Web API key (Identity Toolkit). Production mounts this via Secret Manager
# (see defineSecret('AUTH_API_KEY') in index.js). Local/emulator: set here or in .env.
AUTH_API_KEY=your_firebase_web_api_key

# Optional fallback key name:
FIREBASE_API_KEY=your_firebase_web_api_key

# Orígenes permitidos para el navegador (lista separada por comas, sin espacios obligatorios).
# En producción (NODE_ENV=production) validateEnv() exige al menos un origen no vacío.
#
# Valores típicos para Firebase Hosting del proyecto startandconnect-c44b2:
#   https://startandconnect-c44b2.web.app
#   https://startandconnect-c44b2.firebaseapp.com
# Si tienes dominio propio en Hosting, añádelo también (ej. https://app.tudominio.com).
#
CORS_ORIGINS=https://startandconnect-c44b2.web.app,https://startandconnect-c44b2.firebaseapp.com

# Idempotencia (POST experience-bookings): por defecto Firestore en prod. Opcional local:
# IDEMPOTENCY_STORE=memory

# Regenerar tokens Postman (Experiences E2E): en backend/ ejecutar
#   npm run postman:update-tokens
# Requiere cuentas con rol admin (custom claim) y usuario normal.
POSTMAN_BASE_URL=https://api-ma5t57vzsq-ew.a.run.app
POSTMAN_ADMIN_EMAIL=
POSTMAN_ADMIN_PASSWORD=
POSTMAN_USER_EMAIL=
POSTMAN_USER_PASSWORD=

# Optional third-party integrations:
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_MODE=fixed
STRIPE_CHECKOUT_URL_FIXED=https://book.stripe.com/replace_me
STRIPE_SUCCESS_URL=https://startandconnect-c44b2.web.app/payments/success
STRIPE_CANCEL_URL=https://startandconnect-c44b2.web.app/payments/cancel
