{
  "displayName": "API 5xx error rate high",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "5xx ratio > 5%",
      "conditionThreshold": {
        "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"api\" metric.label.\"response_code_class\"=\"5xx\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.05,
        "duration": "300s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE"
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "enabled": true,
  "severity": "CRITICAL"
}
