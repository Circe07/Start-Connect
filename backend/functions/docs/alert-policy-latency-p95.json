{
  "displayName": "API p95 latency high",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "p95 latency > 1.5s",
      "conditionThreshold": {
        "filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"api\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 1.5,
        "duration": "300s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_PERCENTILE_95"
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "enabled": true,
  "severity": "WARNING"
}
