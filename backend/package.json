{
  "name": "node-express-firebase",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "build": "node -e \"console.log('No build step required for this repository')\"",
    "prepare": "husky install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:hardening": "prettier --check functions/src/**/*.js functions/test/**/*.js functions/docs/**/*.md .github/workflows/backend-release-gates.yml ../testing/backend/*.json",
    "postman:smoke": "newman run testing/frontend/health-smoke.postman_collection.json --env-var baseUrl=http://127.0.0.1:5001/startandconnect-c44b2/europe-west1/api",
    "test:smoke-env": "node testing/scripts/smoke-env.mjs",
    "test:smoke-api": "node testing/scripts/smoke-api.mjs",
    "test:load-smoke": "node testing/scripts/load-smoke.mjs",
    "test:phase1": "npm run test:smoke-env && npm run test:smoke-api && npm test",
    "test:run-all:ps": "powershell -ExecutionPolicy Bypass -File ./testing/scripts/run-all-tests.ps1",
    "test:contract": "jest functions/test/contract.openapi.test.js",
    "test:e2e": "jest functions/test/e2e.mvp.test.js",
    "test:security": "jest functions/test/security.middleware.test.js",
    "test:perf-smoke": "jest functions/test/perf.smoke.test.js",
    "test:all-backend": "npm run test:contract && npm run test:e2e && npm run test:security && npm run test:perf-smoke && npm test",
    "test:all-backend:with-load": "npm run test:all-backend && npm run test:load-smoke",
    "test:release-gate": "node testing/scripts/release-gate.mjs",
    "test:release-readiness": "npm run test:release-gate && npm run test:all-backend",
    "start": "node functions/index.js",
    "dev": "nodemon src/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@google-cloud/firestore": "^7.11.3",
    "cors": "^2.8.5",
    "dotenv": "^11.0.0",
    "express": "^4.21.2",
    "express-handlebars": "^6.0.2",
    "firebase": "^12.5.0",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.6.0",
    "morgan": "^1.10.1",
    "stripe": "^19.1.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^15.5.2",
    "newman": "^6.2.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "supertest": "^7.1.4"
  },
  "lint-staged": {
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
